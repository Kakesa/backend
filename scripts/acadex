#!/usr/bin/env python3
import sys
import os
import subprocess
import tempfile
import time

WAITER_DIR = "/opt/acadex/waiter"
WAITER_LOG = "/tmp/acadex-waiter.log"

def get_orchestrator():
    """Retrieve the orchestrator from environment or fall back to docker-compose."""
    return os.getenv("ACADEX_ORCHESTRATOR", "docker-compose").lower()

def confirm(prompt):
    """Prompt the user for a Yes/No confirmation."""
    resp = input(f"{prompt} [y/N]: ").strip().lower()
    return resp in ('y', 'yes')

def kill():
    """Stops all application containers/resources and the waiter daemon."""
    if not confirm("Are you sure you want to stop all Acadex containers and the Waiter service?"):
        print("Aborted.")
        sys.exit(0)
    
    orch = get_orchestrator()
    print(f"Stopping containers using {orch}...")
    
    if orch == "docker-compose":
        subprocess.run(["docker", "compose", "-p", "acadex", "-f", "/var/acadex/docker-compose.yml", "down"])
    elif orch == "kubernetes":
        # Simplified removal
        subprocess.run(["kubectl", "delete", "-f", "/var/acadex/k8s.yaml"])
    else:
        print(f"Unknown orchestrator: {orch}")
        sys.exit(1)
        
    print("Stopping Waiter daemon...")
    try:
        subprocess.run(["pkill", "-f", "webhook:app"])
        print("Waiter stopped.")
    except Exception:
        print("Waiter was not running.")

def start():
    """Starts the application containers and the waiter daemon."""
    orch = get_orchestrator()
    print(f"Starting containers using {orch}...")
    
    if orch == "docker-compose":
        subprocess.run(["docker", "compose", "-p", "acadex", "-f", "/var/acadex/docker-compose.yml", "up", "-d"])
    elif orch == "kubernetes":
        subprocess.run(["kubectl", "apply", "-f", "/var/acadex/k8s.yaml"])
    else:
        print(f"Unknown orchestrator: {orch}")
        sys.exit(1)
        
    print("Starting Waiter Webhook listener locally (daemon mode)...")
    if not os.path.exists(WAITER_DIR):
        print(f"Waiter install directory not found: {WAITER_DIR}")
        print("Re-run installer: python3 waiter/install.py")
        sys.exit(1)

    try:
        subprocess.run(["pkill", "-f", "webhook:app"], check=False)
        # Start gunicorn in the background using Waiter's configuration
        cmd = f"cd {WAITER_DIR} && nohup python3 -m gunicorn --bind 0.0.0.0:${{PORT:-5050}} webhook:app > {WAITER_LOG} 2>&1 &"
        subprocess.run(cmd, executable='/bin/bash', shell=True, check=True)
        time.sleep(1)
        check = subprocess.run(["pgrep", "-f", "webhook:app"], check=False, capture_output=True, text=True)
        if check.returncode == 0 and check.stdout.strip():
            print("Waiter started successfully.")
        else:
            print("Waiter failed to start. Recent logs:")
            subprocess.run(["tail", "-n", "40", WAITER_LOG], check=False)
            sys.exit(1)
    except Exception as e:
        print(f"Failed to start waiter: {e}")
        subprocess.run(["tail", "-n", "40", WAITER_LOG], check=False)
        sys.exit(1)

def tunnel():
    """Launches ngrok to expose both shadow and waiter endpoints securely."""
    shadow_port = os.getenv("SHADOW_PORT", "5000")
    waiter_port = os.getenv("WAITER_PORT", "5050")
    
    print(f"Starting ngrok tunnels for Shadow ({shadow_port}) and Waiter ({waiter_port})...")
    config = f"""
version: "2"
tunnels:
  shadow:
    proto: http
    addr: {shadow_port}
  waiter:
    proto: http
    addr: {waiter_port}
"""
    with tempfile.NamedTemporaryFile(mode='w', delete=False, suffix=".yml") as f:
        f.write(config)
        config_path = f.name
    
    try:
        # ngrok start --all requires the yaml configuration
        subprocess.run(["ngrok", "start", "--all", "--config", config_path])
    except FileNotFoundError:
        print("Error: ngrok is not installed or not in your PATH.")
        print("Please run the one-time waiter/install.py script to install it, or install it manually.")
    finally:
        os.remove(config_path)

def status():
    """Shows the status of all Acadex services."""
    orch = get_orchestrator()
    print("==========================================")
    print(f" Orchestrator Status ({orch.upper()})")
    print("==========================================")
    
    if orch == "docker-compose":
        subprocess.run(["docker", "compose", "-p", "acadex", "-f", "/var/acadex/docker-compose.yml", "ps"])
    elif orch == "kubernetes":
        subprocess.run(["kubectl", "get", "deployments,pods,services"], check=False)
        err_check = subprocess.run(
            ["kubectl", "get", "pods", "-o", "wide"],
            check=False,
            capture_output=True,
            text=True,
        )
        if "ErrImagePull" in err_check.stdout or "ImagePullBackOff" in err_check.stdout:
            print("\nDetected image pull issue for one or more pods.")
            print("Run: minikube image load acadex-shadow:latest && kubectl rollout restart deployment/shadow")
    else:
        print(f"Unknown orchestrator: {orch}")
        
    print("\n==========================================")
    print(" Waiter Daemon Status")
    print("==========================================")
    try:
        waiter_pids = subprocess.check_output(["pgrep", "-f", "webhook:app"]).decode().strip().split('\n')
        if waiter_pids and waiter_pids[0]:
            print(f"✅ Waiter is RUNNING (PIDs: {', '.join(waiter_pids)})")
        else:
            print("❌ Waiter is STOPPED")
    except subprocess.CalledProcessError:
        print("❌ Waiter is STOPPED")
        if os.path.exists(WAITER_LOG):
            print(f"Last waiter log lines ({WAITER_LOG}):")
            subprocess.run(["tail", "-n", "20", WAITER_LOG], check=False)

    print("\n==========================================")
    print(" Tunnel Status (ngrok)")
    print("==========================================")
    try:
        ngrok_pids = subprocess.check_output(["pgrep", "-x", "ngrok"]).decode().strip().split('\n')
        if ngrok_pids and ngrok_pids[0]:
            print(f"✅ Ngrok is RUNNING (PIDs: {', '.join(ngrok_pids)})")
        else:
            print("❌ Ngrok tunnel is STOPPED")
    except subprocess.CalledProcessError:
        print("❌ Ngrok tunnel is STOPPED")
    print()

def uninstall():
    """Uninstalls Acadex and removes configuration files."""
    if not confirm("Are you sure you want to completely uninstall Acadex and remove its files?"):
        print("Aborted.")
        sys.exit(0)
    
    # First, try to kill processes
    orch = get_orchestrator()
    print(f"Stopping containers using {orch}...")
    if orch == "docker-compose":
        subprocess.run(["docker", "compose", "-p", "acadex", "-f", "/var/acadex/docker-compose.yml", "down"], check=False)
    elif orch == "kubernetes":
        subprocess.run(["kubectl", "delete", "-f", "/var/acadex/k8s.yaml"], check=False)
        
    print("Stopping Waiter daemon...")
    subprocess.run(["pkill", "-f", "webhook:app"], check=False)

    print("Removing /var/acadex configuration files...")
    subprocess.run(["sudo", "rm", "-rf", "/var/acadex"])
    
    print("Removing /opt/acadex/waiter daemon logs and scripts...")
    subprocess.run(["sudo", "rm", "-rf", "/opt/acadex"])
    
    print("Removing acadex CLI...")
    subprocess.run(["sudo", "rm", "-f", "/usr/local/bin/acadex"])
    
    print("Uninstallation complete.")

def main():
    if len(sys.argv) < 2:
        print("Usage: scripts/acadex <command>")
        print("\nCommands:")
        print("  start     - Starts all containers using the defined orchestrator")
        print("  kill      - Stops all containers (requires confirmation)")
        print("  tunnel    - Launches ngrok to tunnel shadow and waiter")
        print("  status    - Shows the running status of containers, waiter, and tunnels")
        print("  uninstall - Removes all running containers and deletes Acadex configuration files")
        sys.exit(1)
        
    cmd = sys.argv[1].lower()
    
    if cmd == "start":
        start()
    elif cmd == "kill":
        kill()
    elif cmd == "tunnel":
        tunnel()
    elif cmd == "status":
        status()
    elif cmd == "uninstall":
        uninstall()
    else:
        print(f"Unknown command: {cmd}")
        sys.exit(1)

if __name__ == '__main__':
    main()
